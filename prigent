<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fanch Prigent — Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --dark: #0f1117;
    --darker: #080b10;
    --panel: #161b27;
    --accent: #4f9cf9;
    --accent2: #7b5ea7;
    --text: #e8eaf0;
    --muted: #7a8099;
    --border: rgba(255,255,255,0.07);
    --card: rgba(255,255,255,0.04);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--darker);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    overflow-x: hidden;
  }

  /* NOISE TEXTURE */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    background-size: 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.5;
  }

  /* NAV */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 1.2rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(8,11,16,0.85);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    color: var(--text);
    text-decoration: none;
  }

  .nav-logo span { color: var(--accent); }

  .nav-links { display: flex; gap: 2rem; }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.88rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--text); }

  /* HERO */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 3rem 5rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 70% 50%, rgba(79,156,249,0.08) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 30% 80%, rgba(123,94,167,0.07) 0%, transparent 60%);
    pointer-events: none;
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(79,156,249,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(79,156,249,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    border: 1px solid rgba(79,156,249,0.25);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.2s forwards;
  }

  .hero-tag::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .hero-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: clamp(3rem, 5vw, 4.5rem);
    line-height: 1;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.35s forwards;
  }

  .hero-name .accent { color: var(--accent); }

  .hero-title {
    font-size: 1.15rem;
    color: var(--muted);
    font-weight: 300;
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.5s forwards;
  }

  .hero-desc {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--muted);
    max-width: 460px;
    opacity: 0;
    animation: fadeUp 0.6s 0.65s forwards;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    margin-top: 2.5rem;
    opacity: 0;
    animation: fadeUp 0.6s 0.8s forwards;
  }

  .btn-primary {
    padding: 0.75rem 1.8rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-primary:hover { background: #3a8be8; transform: translateY(-2px); }

  .btn-secondary {
    padding: 0.75rem 1.8rem;
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 400;
    cursor: pointer;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-secondary:hover { border-color: var(--accent); color: var(--accent); }

  /* HERO RIGHT — STATS CARD */
  .hero-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2rem;
    backdrop-filter: blur(10px);
    opacity: 0;
    animation: fadeUp 0.7s 0.9s forwards;
  }

  .hero-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.8rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .avatar-circle {
    width: 58px; height: 58px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;
    color: #fff;
    flex-shrink: 0;
  }

  .hero-card-name { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 1rem; }
  .hero-card-sub { font-size: 0.82rem; color: var(--muted); margin-top: 2px; }

  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-box {
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem;
  }

  .stat-num {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.6rem;
    color: var(--accent);
  }

  .stat-label { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }

  .contact-row {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.83rem;
    color: var(--muted);
  }

  .contact-icon {
    width: 28px; height: 28px;
    border-radius: 7px;
    background: rgba(79,156,249,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  /* SECTION COMMON */
  section {
    position: relative;
    z-index: 1;
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.7rem;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(2rem, 3vw, 2.8rem);
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 500px;
    line-height: 1.7;
    margin-bottom: 3.5rem;
  }

  /* DIVIDER */
  .divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0 3rem;
  }

  /* EXPERIENCE */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(to bottom, var(--accent), transparent);
  }

  .timeline-item {
    position: relative;
    margin-bottom: 3rem;
    padding-left: 2rem;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s;
  }

  .timeline-item.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 0.4rem;
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--accent);
    border: 2px solid var(--darker);
    box-shadow: 0 0 0 4px rgba(79,156,249,0.15);
  }

  .timeline-date {
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }

  .timeline-role {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    margin-bottom: 0.2rem;
  }

  .timeline-company {
    font-size: 0.88rem;
    color: var(--muted);
    margin-bottom: 0.8rem;
  }

  .timeline-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .timeline-bullets li {
    font-size: 0.88rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
  }

  .timeline-bullets li::before {
    content: '›';
    position: absolute;
    left: 0;
    color: var(--accent);
  }

  /* SKILLS */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.6rem;
    transition: all 0.3s;
    opacity: 0;
    transform: translateY(20px);
  }

  .skill-card.visible { opacity: 1; transform: translateY(0); }
  .skill-card:hover { border-color: rgba(79,156,249,0.3); background: rgba(79,156,249,0.04); }

  .skill-card-icon {
    width: 40px; height: 40px;
    border-radius: 10px;
    background: rgba(79,156,249,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .skill-card-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.8rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    font-size: 0.75rem;
    padding: 0.25rem 0.65rem;
    border-radius: 6px;
    background: rgba(255,255,255,0.05);
    color: var(--muted);
    border: 1px solid var(--border);
  }

  /* FORMATION */
  .formation-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .formation-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.8rem;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.4s;
  }

  .formation-card.visible { opacity: 1; transform: translateY(0); }

  .formation-year {
    font-size: 0.78rem;
    color: var(--accent);
    letter-spacing: 0.08em;
    margin-bottom: 0.5rem;
  }

  .formation-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 1rem;
    margin-bottom: 0.3rem;
  }

  .formation-school {
    font-size: 0.85rem;
    color: var(--muted);
  }

  /* CONTACT SECTION */
  .contact-section {
    background: var(--panel);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 5rem 3rem;
  }

  .contact-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .contact-info-items {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-top: 2.5rem;
  }

  .contact-info-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .contact-info-icon {
    width: 42px; height: 42px;
    border-radius: 11px;
    background: rgba(79,156,249,0.1);
    border: 1px solid rgba(79,156,249,0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .contact-info-label { font-size: 0.75rem; color: var(--muted); }
  .contact-info-value { font-weight: 500; }

  .contact-cta-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 2.5rem;
    text-align: center;
  }

  .contact-cta-box h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    margin-bottom: 0.7rem;
  }

  .contact-cta-box p {
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.8rem;
  }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 2rem;
    font-size: 0.8rem;
    color: var(--muted);
    border-top: 1px solid var(--border);
  }

  /* CV PROTÉGÉ */
  .cv-section {
    padding: 6rem 3rem;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .cv-lock-box {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3rem;
    max-width: 480px;
    margin: 3rem auto 0;
    text-align: center;
  }

  .cv-lock-icon {
    width: 60px; height: 60px;
    background: rgba(79,156,249,0.12);
    border: 1px solid rgba(79,156,249,0.25);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.6rem;
    margin: 0 auto 1.5rem;
  }

  .cv-lock-box h3 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 1.2rem;
    margin-bottom: 0.6rem;
  }

  .cv-lock-box p {
    color: var(--muted);
    font-size: 0.88rem;
    margin-bottom: 1.8rem;
    line-height: 1.6;
  }

  .cv-input-row {
    display: flex;
    gap: 0.7rem;
  }

  .cv-input {
    flex: 1;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .cv-input:focus { border-color: var(--accent); }
  .cv-input.error { border-color: #e05555; animation: shake 0.35s; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    75% { transform: translateX(6px); }
  }

  .cv-error-msg {
    color: #e05555;
    font-size: 0.8rem;
    margin-top: 0.6rem;
    display: none;
  }

  .cv-content {
    display: none;
    margin-top: 3rem;
  }

  .cv-content.visible { display: block; }

  .cv-frame {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    overflow: hidden;
  }

  .cv-frame-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.2rem 1.8rem;
    border-bottom: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
  }

  .cv-frame-title {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .cv-frame-title span { color: var(--muted); font-family: 'DM Sans', sans-serif; font-weight: 300; font-size: 0.82rem; }

  .cv-frame-body {
    padding: 2.5rem;
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
  }

  /* CV LEFT PANEL */
  .cv-left {
    background: #1a2035;
    border-radius: 12px;
    padding: 2rem;
  }

  .cv-avatar {
    width: 70px; height: 70px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Syne', sans-serif;
    font-weight: 800; font-size: 1.4rem; color: #fff;
    margin: 0 auto 1.5rem;
  }

  .cv-section-head {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid rgba(79,156,249,0.2);
    padding-bottom: 0.4rem;
    margin-bottom: 1rem;
    margin-top: 1.5rem;
  }

  .cv-left-item {
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .cv-left-item strong { color: var(--text); display: block; font-weight: 500; }

  .cv-tag-list { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .cv-tag {
    font-size: 0.72rem;
    padding: 0.2rem 0.55rem;
    border-radius: 5px;
    background: rgba(79,156,249,0.1);
    color: var(--accent);
    border: 1px solid rgba(79,156,249,0.2);
  }

  /* CV RIGHT */
  .cv-right {}

  .cv-name {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 2rem;
    margin-bottom: 0.3rem;
  }

  .cv-subtitle {
    color: var(--muted);
    font-size: 0.9rem;
    margin-bottom: 0.8rem;
  }

  .cv-desc-text {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .cv-exp-item { margin-bottom: 1.5rem; }
  .cv-exp-role {
    font-family: 'Syne', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
  }
  .cv-exp-company { font-size: 0.82rem; color: var(--accent); margin-bottom: 0.5rem; }
  .cv-exp-bullets { list-style: none; }
  .cv-exp-bullets li {
    font-size: 0.82rem;
    color: var(--muted);
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
    margin-bottom: 0.25rem;
  }
  .cv-exp-bullets li::before { content: '›'; position: absolute; left: 0; color: var(--accent); }

  @media (max-width: 900px) {
    .cv-frame-body { grid-template-columns: 1fr; }
    .cv-section { padding: 4rem 1.5rem; }
    .cv-lock-box { padding: 2rem; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-content { grid-template-columns: 1fr; gap: 3rem; }
    .formation-grid { grid-template-columns: 1fr; }
    .contact-inner { grid-template-columns: 1fr; gap: 3rem; }
    nav { padding: 1rem 1.5rem; }
    nav .nav-links { display: none; }
    section { padding: 4rem 1.5rem; }
    .hero { padding: 7rem 1.5rem 4rem; }
  }
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a href="#" class="nav-logo">F<span>.</span>Prigent</a>
  <div class="nav-links">
    <a href="#experience">Expérience</a>
    <a href="#competences">Compétences</a>
    <a href="#formation">Formation</a>
    <a href="#contact">Contact</a>
    <a href="#cv">CV</a>
    <a href="#fiche">Fiche E5</a>
    <a href="#veille">Veille</a>
  </div>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
